{
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest"
  },
  "permissions": {
    "allow": [
      "Bash(node .claude/*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "PostToolUse": [{
    "matcher": "Edit|Write",
    "hooks": [{"type": "command", "command": "npm run lint --silent && npx tsc --noEmit"}]
  }]
}
